    {
      "contract": "PublicShell",
      "path": "components/public/PublicShell.js",
      "status": "active"
    },
    {
      "contract": "PageHeader",
      "path": "components/NarimatoPageHeader.js",
      "status": "active"
    },
    {
      "contract": "StateBlock",
      "path": "components/NarimatoGdsAlert.js",
      "status": "active"
    },
    {
      "contract": "SemanticButton",
      "path": "components/NarimatoSemanticButton.js",
      "status": "active"
    },
    {
      "contract": "AccentPanel",
      "path": "components/NarimatoAccentPanel.js",
      "status": "active"
    },
    {
      "contract": "FormField",
      "path": "components/NarimatoFormField.js",
      "status": "active"
    },
    {
      "contract": "MetricCard",
      "path": "components/NarimatoMetricCard.js",
      "status": "active"
    }
