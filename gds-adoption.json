  "approvedExceptions": [
    {
      "surface": "Immersive play UI",
      "reason": "Full-viewport swipe/vote surfaces use governed GdsIcons but exempt from shell-oriented ci-gds-guard rules.",
      "owner": "narimato",
      "reviewDate": "2026-08-01"
    },
    {
      "surface": "NarimatoSemanticButton SSR fallback",
      "reason": "Prerender uses Mantine Button without color= until client SemanticButton hydrates.",
      "owner": "narimato",
      "reviewDate": "2026-08-01"
    },
    {
      "surface": "Play layout CSS module",
      "reason": "playGame.module.css holds immersive layout tokens outside shell contracts.",
      "owner": "narimato",
      "reviewDate": "2026-08-01"
    },
    {
      "surface": "Mantine notifications API",
      "reason": "notifications.show color prop is Mantine overlay API, not shell markup.",
      "owner": "narimato",
      "reviewDate": "2026-08-01"
    }
  ],
  "compliance": {
    "documentationPaths": [
      "README.md",
      "docs/GDS_ADOPTION.md",
      "WARP.md"
    ],
    "staleDocumentationReferences": [
      "@gds/core",
      "@gds/theme",
      "file:./packages/gds-",
      "file:../general-design-system",
      "vercel-install-gds",
      "build-gds-packages",
      "GENERAL_DESIGN_SYSTEM",
      "gds:sync",
      "npm run gds:sync"
    ],
    "protectedSurfacePaths": [
      "components/public",
      "components/operator",
      "components/play/PlayPicker.js",
      "lib/ui"
    ],
    "bannedImports": [
      "@gds/core",
      "@gds/theme",
      "@gds/admin"
    ]
  },
  "migrationStatus": "package-first",
  "owner": "narimato",
  "lastReviewedAt": "2026-05-26"
}
