{
  "schemaVersion": 1,
  "gdsVersion": "2.6.4",
  "productArchetype": "hybrid",
  "supportedEntryPoints": [
    "@doneisbetter/gds-theme/client",
    "@doneisbetter/gds-theme/server",
    "@doneisbetter/gds-core/client",
    "@doneisbetter/gds-core/server",
    "@doneisbetter/gds-admin/client",
    "@doneisbetter/gds-admin/server"
  ],
  "requiredContracts": [
    "GdsProvider",
    "PublicShell",
    "PageHeader",
    "StateBlock",
    "SemanticButton",
    "StatusBadge",
    "EmptyState",
    "ConfirmDialog",
    "AppShell",
    "AuthShell",
    "DiscoveryShell",
    "SidebarNav",
    "SidebarNavItem",
    "PublicBrandFooter"
  ],
  "localAdapters": [
    {
      "contract": "GdsProvider",
      "path": "components/NarimatoProviders.js",
      "status": "active"
    },
    {
      "contract": "Theme",
      "path": "lib/ui/narimatoTheme.js",
      "status": "active"
    },
    {
      "contract": "PublicShell",
      "path": "components/public/PublicShell.js",
      "status": "active"
    },
    {
      "contract": "PublicChrome",
      "path": "lib/ui/publicChrome.js",
      "status": "active"
    },
    {
      "contract": "AppShell",
      "path": "components/operator/NarimatoOperatorShell.js",
      "status": "active"
    },
    {
      "contract": "AppShell",
      "path": "components/admin/AdminShell.js",
      "status": "active"
    },
    {
      "contract": "Notifications",
      "path": "lib/ui/notifications.js",
      "status": "active"
    }
  ],
  "approvedExceptions": [
    {
      "surface": "Immersive play UI",
      "reason": "Full-viewport swipe/vote surfaces use governed GdsIcons but exempt from shell-oriented ci-gds-guard rules.",
      "owner": "narimato",
      "reviewDate": "2026-08-01",
      "category": "product-authored-experience",
      "scope": [
        "components/play/PlaySwipeSurface.js",
        "components/play/PlayVoteSurface.js"
      ],
      "allowedImplementation": "Mantine layout primitives for gesture-first play cards.",
      "mustStillUse": [
        "@doneisbetter/gds-core/client GdsIcons",
        "StatusBadge for in-card level labels"
      ],
      "mustNotDo": [
        "Add parallel marketing shells or raw palette accent panels inside play surfaces"
      ],
      "exitCondition": "GDS publishes an immersive play runtime contract or Narimato retires swipe game modes.",
      "status": "approved",
      "allowImports": ["@mantine/core"]
    },
    {
      "surface": "Play layout CSS module",
      "reason": "playGame.module.css holds immersive layout tokens outside shell contracts.",
      "owner": "narimato",
      "reviewDate": "2026-08-01",
      "category": "product-authored-experience",
      "scope": [
        "styles/playGame.module.css"
      ],
      "allowedImplementation": "Local CSS module for swipe physics, card transforms, and safe-area layout.",
      "mustStillUse": [
        "GDS theme tokens via Mantine CSS variables where referenced"
      ],
      "mustNotDo": [
        "Duplicate shell spacing, typography, or marketing accent rules in play CSS"
      ],
      "exitCondition": "GDS documents immersive play layout tokens or play modes are removed.",
      "status": "approved"
    }
  ],
  "compliance": {
    "strictMode": true,
    "approvedShellPrimitives": [
      "PublicShell",
      "AppShell",
      "DiscoveryShell",
      "AuthShell",
      "PublicBrandFooter"
    ],
    "approvedTemporaryExceptions": [
      "PublicChrome"
    ],
    "approvedActionPrimitives": [
      "SemanticButton",
      "ActionBar",
      "ChoiceChip",
      "ConfirmDialog"
    ],
    "documentationPaths": [
      "README.md",
      "docs/GDS_ADOPTION.md",
      "WARP.md"
    ],
    "staleDocumentationReferences": [
      "@gds/core",
      "@gds/theme",
      "file:./packages/gds-",
      "file:../general-design-system",
      "releases/download/gds-v",
      "doneisbetter-gds-",
      "vercel-install-gds",
      "build-gds-packages",
      "GENERAL_DESIGN_SYSTEM",
      "gds:sync",
      "npm run gds:sync"
    ],
    "protectedSurfacePaths": [
      "components/public",
      "components/operator",
      "components/play/PlayPicker.js",
      "lib/ui"
    ],
    "bannedImports": [
      "@gds/core",
      "@gds/theme",
      "@gds/admin",
      "@tabler/icons-react",
      "@mantine/notifications"
    ]
  },
  "migrationStatus": "governed",
  "owner": "narimato",
  "lastReviewedAt": "2026-05-28"
}
