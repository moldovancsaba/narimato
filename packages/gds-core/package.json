{
  "name": "@gds/core",
  "version": "2.4.3",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "@gds/theme": "^2.4.3",
    "@mantine/core": "^7.9.0",
    "@mantine/hooks": "^7.9.0",
    "@tabler/icons-react": "^3.5.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@gds/theme": "*",
    "@mantine/core": "^7.9.0",
    "@mantine/hooks": "^7.9.0",
    "@tabler/icons-react": "^3.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
