{
  "extends": "next/core-web-vitals",
  "plugins": ["fieldnames"],
  "rules": {
    "fieldnames/field-naming-consistency": "warn"
  },
  "overrides": [
    {
      "files": ["pages/_document.js"],
      "rules": { "@next/next/no-css-tags": "off" }
    },
    {
      "files": ["pages/**/*.js"],
      "rules": { "@next/next/no-img-element": "off" }
    }
  ]
}
